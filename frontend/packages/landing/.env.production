# Committed production defaults for the landing build.
# Vite + Bun auto-load this file when NODE_ENV=production (any `vite build`
# or `bun run build` invocation). Anything secret belongs in
# .env.production.local (gitignored) or your deploy platform's dashboard.

# Canonical origin baked into dist/{llms.txt, robots.txt, sitemap.xml} and
# the runtime-emitted canonical / og:url / hreflang link tags.
VITE_SITE_URL=https://bsz.saop.cc

# Live Stats grid at the top of the landing. Same-origin in production
# (landing + Rust backend share bsz.saop.cc behind the reverse proxy), so
# the POST /api call carries the busuanziId cookie without extra CORS work.
VITE_DEMO_API=https://bsz.saop.cc

# Artalk comments. Mirrors the production setup from the original deploy.
VITE_ARTALK_SERVER=https://artalk.saop.cc
VITE_ARTALK_SITE_NAME=不蒜子.rs
