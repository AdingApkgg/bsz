# Landing env vars. Vite auto-loads .env / .env.local / .env.<mode> /
# .env.<mode>.local from this package's root and inlines every VITE_*
# value into the bundle. Bun also picks them up when running the
# postbuild script, so VITE_SITE_URL flows into dist/{llms,robots,sitemap}.
#
# Recommended:
#   cp .env.example .env.local           # personal dev overrides
#   cp .env.example .env.production      # committed prod defaults (no secrets)
# Or just set them on your deploy platform (Vercel / Cloudflare / Netlify
# dashboards, GitHub Actions secrets) and skip the files entirely.

# Canonical origin for this deploy, no trailing slash. Baked into
# dist/llms.txt, dist/robots.txt, and dist/sitemap.xml by the postbuild
# script so sitemaps and LLM docs point at the right hostname.
# Unset → those files reference a clearly-fake placeholder URL.
VITE_SITE_URL=

# Optional. Backend URL for the live PV/UV demo block on the landing page.
# Unset → the Stats section is hidden. Set to your busuanzi backend origin
# (no trailing slash) to enable: VITE_DEMO_API=https://bsz.example.com
VITE_DEMO_API=

# Optional. Artalk server base URL for the Comments section.
# Unset → Comments hidden. Set to your Artalk server origin to enable:
# VITE_ARTALK_SERVER=https://artalk.example.com
VITE_ARTALK_SERVER=

# Optional display name shown by Artalk. Defaults to "Busuanzi".
VITE_ARTALK_SITE_NAME=
